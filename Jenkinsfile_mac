pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            stages {
                stage('Build App Image') {
                    steps {
                        sh "/usr/local/bin/docker compose build app"
                    }
                }
                stage('Validate Compose Config') {
                    steps {
                        sh "/usr/local/bin/docker compose config"
                    }
                }
            }
        }

        stage('Deploy') {
            stages {
                stage('Stop Existing Containers') {
                    steps {
                        sh "/usr/local/bin/docker compose down || true"
                    }
                }
                stage('Start Database Container') {
                    steps {
                        sh "/usr/local/bin/docker compose up -d db"
                    }
                }
                stage('Wait for Database Health') {
                    steps {
                        sh "sleep 20"
                    }
                }
                stage('Start Application Container') {
                    steps {
                        sh "/usr/local/bin/docker compose up -d app"
                    }
                }
            }
        }

        stage('Verify') {
            steps {
                sh "/usr/local/bin/docker compose ps"
            }
        }
    }

    post {
        success {
            echo "Deployed! Visit http://localhost"
        }
        failure {
            echo "Pipeline failed. Check logs above."
        }
    }
}
